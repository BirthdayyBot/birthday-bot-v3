CLIENT_VERSION=3.0.0-dev

CLIENT_ID=
CLIENT_PRESENCE_NAME="Birthdayy | /help"
CLIENT_PRESENCE_TYPE=WATCHING


COMMAND_GUILD_IDS=

# InfluxDB
INFLUX_ENABLED=false
INFLUX_URL=http://influxdb:8086
