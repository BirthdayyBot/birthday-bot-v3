# Redis
REDIS_PORT=6379
REDIS_PASSWORD=redis
REDIS_HOST=redis
REDIS_CACHE_DB=0
REDIS_TASK_DB=1

# Error Webhook
WEBHOOK_ERROR_ID=
WEBHOOK_ERROR_TOKEN=

# Tokens
DISCORD_TOKEN=