        "edit": {
          "generalTitle": "Edit General Settings",
          "announcementsTitle": "Edit Birthday Announcements",
          "birthdayRoleTitle": "Edit Birthday Role",
          "overviewAndLogsTitle": "Edit Overview & Logs",
