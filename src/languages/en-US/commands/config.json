      "responses": {
        "updated": "Overview channel set to <#{{channelId}}>."
      }
    },
    "overviewMessage": {
      "responses": {
        "empty": "Overview message cannot be empty.",
        "updated": "Overview message set to `{{message}}`."
      }
    },
    "overviewSort": {
      "options": {
        "sort": {
          "choices": {
            "month": "By month",
            "upcoming": "Upcoming first"
          }
        }
      },
      "responses": {
        "updated": "Overview sort mode set to **{{mode}}**."
      }
    },
    "birthdayRole": {
      "responses": {
        "updated": "Birthday role set to <@&{{roleId}}>."
      }
    },
    "birthdayPingRole": {
      "responses": {
        "updated": "Birthday ping role set to <@&{{roleId}}>."
      }
    },
    "logChannel": {
      "responses": {
        "updated": "Log channel set to <#{{channelId}}>."
      }
    },
    "language": {
      "options": {
        "language": {
          "choices": {
            "enUS": "English (US)",
            "frFR": "French (France)"
          }
        }
      },
