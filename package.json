{
  "name": "birthdayy-bot",
  "version": "1.0.0",
  "main": "dist/index.js",
  "author": "@sapphire",
  "license": "UNLICENSE",
  "module": "dist/index.mjs",
  "private": true,
  "type": "module",
  "imports": {
    "#lib/*": "./dist/lib/*.mjs",
    "#root/*": "./dist/*.mjs",
    "#utils/*": "./dist/lib/util/*.mjs"
  },
  "dependencies": {
    "@discordjs/core": "^2.4.0",
    "@influxdata/influxdb-client": "^1.35.0",
    "@kaname-png/plugin-subcommands-advanced": "^2.5.0",
    "@sapphire/bitfield": "^1.2.4",
    "@sapphire/decorators": "^6.2.0",
    "@sapphire/discord.js-utilities": "^7.3.3",
    "@sapphire/fetch": "^3.0.5",
    "@sapphire/framework": "^5.5.0",
    "@sapphire/plugin-api": "^8.3.1",
    "@sapphire/plugin-i18next": "^8.0.0",
    "@sapphire/plugin-logger": "^4.1.0",
    "@sapphire/plugin-scheduled-tasks": "^10.0.4",
    "@sapphire/plugin-subcommands": "^7.0.1",
    "@sapphire/time-utilities": "^1.7.14",
    "@sapphire/utilities": "^3.18.2",
    "@skyra/env-utilities": "^1.3.0",
    "@skyra/start-banner": "^2.0.2",
    "colorette": "^2.0.20",
    "discord.js": "^14.26.3",
    "figlet": "^1.11.0",
    "gradient-string": "^3.0.0",
    "kysely": "^0.28.16",
    "mysql2": "^3.22.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@sapphire/cli": "^1.9.3",
    "@sapphire/eslint-config": "^5.0.6",
    "@sapphire/prettier-config": "^2.0.0",
    "@sapphire/ts-config": "^5.0.3",
    "@types/node": "^22.19.17",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.5",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tsc-watch": "^6.3.1",
    "tsdown": "^0.21.9",
    "tsx": "^4.21.0",
    "typescript": "~5.4.5",
    "vitest": "^3.2.4"
  },
  "scripts": {
    "start": "node --preserve-symlinks --enable-source-maps dist/index.mjs",
    "lint": "eslint src --ext ts --fix",
    "prettier": "prettier --ignore-path=.prettierignore",
    "format": "prettier --write .",
    "build": "tsdown",
    "watch": "tsdown --watch",
    "clean": "rimraf dist/",
    "typecheck": "tsc -b src",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "dev": "tsdown --watch --onSuccess \"yarn start\"",
    "migrate": "node --env-file=src/.env --import tsx/esm scripts/migrate.ts up",
    "migrate:down": "node --env-file=src/.env --import tsx/esm scripts/migrate.ts down",
    "import:birthdays:fixture": "node --env-file=src/.env scripts/import-birthdays-fixture.mjs"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "*": "prettier --ignore-unknown --write",
    "*.{mjs,js,ts}": "eslint --fix --ext mjs,js,ts"
  },
  "prettier": "@sapphire/prettier-config",
  "packageManager": "yarn@4.14.1"
}
